# Database
DATABASE_URL=postgres://chronotranslate:chronotranslate@localhost:5432/chronotranslate

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# JWT
JWT_SECRET=change_me_in_production

# Superadmin: the Discord user ID that automatically receives superadmin on login
# Only one superadmin exists at a time. Leave unset to disable.
SUPERADMIN_DISCORD_ID=

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173

# GitHub App (Milestone 4)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_WEBHOOK_SECRET=
